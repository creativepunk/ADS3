{
  "name": "@my-ds/components",
  "version": "0.1.0",
  "description": "Lit Web Components for My Design System",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./src/*": "./src/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist storybook-static",
    "storybook": "pnpm cem && storybook dev -p 6006",
    "storybook:build": "pnpm cem && storybook build",
    "cem": "cem analyze"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@material-symbols/svg-400": "^0.44.10",
    "@my-ds/tokens": "workspace:*",
    "lit": "^3.1.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/blocks": "^8.6.0",
    "@storybook/web-components": "^10.4.6",
    "@storybook/web-components-vite": "^10.4.6",
    "rimraf": "^5.0.5",
    "storybook": "^10.4.6",
    "typescript": "^5.3.3",
    "vite": "^5.4.0"
  },
  "customElements": "custom-elements.json"
}
